# Shopify Connector MCP — runtime environment.
# The installer writes this for you; edit to point at your store(s).

# ---------------------------------------------------------------------------
# Data source. Two ways to run:
#
#  A) LIVE (no database) — recommended for a quick, portable setup. Leave
#     DATABASE_URL unset. The MCP serves every tool real-time from the Shopify
#     Admin API (and OrderGroove REST). Connect any number of stores below.
#
#  B) DB-BACKED — set DATABASE_URL to a Postgres instance you sync into.
#
# Force the mode explicitly with MCP_DATA_SOURCE=live|db (otherwise it
# auto-detects: db when DATABASE_URL is set, else live).
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
# MCP_DATA_SOURCE=live

# Shopify Admin API version. Optional — defaults to 2026-04 in code.
# SHOPIFY_API_VERSION=2026-04

# ---------------------------------------------------------------------------
# Stores — one block per storefront. Discovery is dynamic: any
# SHOPIFY_<KEY>_SHOP defines a store with canonical store_key <KEY> (lowered).
# Auth is token-preferred: set an Admin API access token (shpat_...) OR a
# client_id + client_secret pair.
# ---------------------------------------------------------------------------
# SHOPIFY_MYSTORE_SHOP=mystore.myshopify.com
# SHOPIFY_MYSTORE_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SHOPIFY_MYSTORE_READ_ONLY=true
# Optional OrderGroove subscriptions for this store:
# ORDERGROOVE_MYSTORE_API_KEY=

# HTTP transport in live mode (python -m mcp_server --http) needs a static
# bearer token (no DB token store). Stdio needs none.
# MCP_STATIC_TOKEN=replace-with-a-long-random-string
