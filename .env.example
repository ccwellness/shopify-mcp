# =============================================================================
# Shopify Multi-Store Connector — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================================
# All values below are PLACEHOLDERS. Phase 0 discovery has not happened yet —
# real per-store tokens, webhook secrets, and GA4 IDs land here once each
# Custom App is provisioned (or located, if it already exists) and the
# discovery worksheet in docs/discovery.md is filled in.
# =============================================================================

# ---------- Flask app ----------
FLASK_APP=app:create_app
FLASK_ENV=development
FLASK_SECRET_KEY=replace-with-a-long-random-string
FLASK_DEBUG=1

# Public URL the tunnel exposes (Cloudflare Tunnel / ngrok). Used when
# registering webhook subscriptions: Shopify must be able to POST here.
WEBHOOK_BASE_URL=https://your-tunnel-subdomain.trycloudflare.com

# ---------- Database ----------
# Optional. When DATABASE_URL is set the connector/MCP run in DB-backed mode
# (orders, analytics, etc. served from Postgres). When it is ABSENT, the MCP
# runs in live mode: the same tools are served real-time from the Shopify
# Admin API + OrderGroove REST, with no database.
DATABASE_URL=postgresql+psycopg://shopify_connector:dev_password@localhost:5432/shopify_connector

# ---------- MCP data source ----------
# Force the mode regardless of DATABASE_URL: 'db' or 'live'. Leave unset to
# auto-detect (db when DATABASE_URL is set, else live).
# MCP_DATA_SOURCE=live
#
# Live mode has no DB token store, so the HTTP transport (--http) requires a
# single static bearer token. Stdio (Claude Desktop / Code) needs no auth.
# MCP_STATIC_TOKEN=replace-with-a-long-random-string

# ---------- Redis (RQ broker) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- API auth ----------
# Default expiry (days) for bearer tokens minted via the admin view.
API_TOKEN_DEFAULT_EXPIRY_DAYS=90

# ---------- Shopify API version ----------
# Pin to a specific quarterly release; upgrade quarterly.
SHOPIFY_API_VERSION=2026-04

# =============================================================================
# Per-store credentials --- three blocks, one per storefront.
#
# Each store's Custom App is created via the Shopify Dev Dashboard at
#   https://dev.shopify.com/dashboard/
# (the legacy Admin-UI custom-app flow was removed on 2026-01-01).
#
# The Dashboard issues OAuth 2 client credentials per app:
#   - SHOPIFY_<STORE>_CLIENT_ID      (public-ish identifier)
#   - SHOPIFY_<STORE>_CLIENT_SECRET  (sensitive --- treat like a password)
#
# At runtime the connector POSTs these to
#   https://{shop}.myshopify.com/admin/oauth/access_token
# with grant_type=client_credentials and receives a 24-hour access token,
# which it caches in memory and uses in the X-Shopify-Access-Token header
# on every GraphQL call. See docs/custom_app_setup.md for the full flow.
#
# WEBHOOK_SECRET defaults to client_secret on the assumption that Shopify
# still uses it as the HMAC signing key for webhook verification (legacy
# behavior). The Phase 1 webhook receiver verifies against a known good
# signed delivery before this is relied on. Leave blank to fall back to
# CLIENT_SECRET.
#
# DYNAMIC DISCOVERY: stores are discovered from the environment — every
# SHOPIFY_<KEY>_SHOP variable defines a store whose canonical store_key is
# <KEY> lowercased. Add as many as you like; no code change needed. The three
# blocks below are examples, not a fixed roster.
#
# GETTING CREDENTIALS: the Dev Dashboard (https://dev.shopify.com/dashboard/)
# is the only way to create an app now — the in-admin "Develop apps" custom-app
# flow (which used to hand out an shpat_ Admin API token) was removed. The
# Dashboard issues CLIENT_ID + CLIENT_SECRET; the connector exchanges them for
# a 24h token automatically. That OAuth pair is the path for every store.
#
# OPTIONAL TOKEN OVERRIDE: if you already hold an Admin API access token from
# somewhere else, set SHOPIFY_<KEY>_ACCESS_TOKEN=shpat_... and it's used as-is
# (skips the OAuth exchange). You can't mint a fresh one from the store admin
# anymore, so this is an override, not the onboarding path.
#
# A store is registered if it has a shop domain AND either a client_id +
# client_secret pair or an access token.
# =============================================================================

# ---------- lubelife.com ----------
SHOPIFY_LUBELIFE_SHOP=lubelife.myshopify.com
SHOPIFY_LUBELIFE_CLIENT_ID=replace-with-client-id-from-dev-dashboard
SHOPIFY_LUBELIFE_CLIENT_SECRET=replace-with-client-secret-from-dev-dashboard
SHOPIFY_LUBELIFE_WEBHOOK_SECRET=
SHOPIFY_LUBELIFE_PLUS=false                         # confirmed Phase 0 (Advanced plan)
SHOPIFY_LUBELIFE_SUBSCRIPTION_PROVIDER=ordergroove  # confirmed Phase 0
SHOPIFY_LUBELIFE_READ_ONLY=true                     # v1 enforces; do not change

# ---------- shopjo.com ----------
SHOPIFY_SHOPJO_SHOP=system-jo.myshopify.com         # actual handle (NOT shopjo.myshopify.com)
SHOPIFY_SHOPJO_CLIENT_ID=replace-with-client-id-from-dev-dashboard
SHOPIFY_SHOPJO_CLIENT_SECRET=replace-with-client-secret-from-dev-dashboard
SHOPIFY_SHOPJO_WEBHOOK_SECRET=
SHOPIFY_SHOPJO_PLUS=false                           # confirmed Phase 0 (Advanced plan)
SHOPIFY_SHOPJO_SUBSCRIPTION_PROVIDER=ordergroove    # confirmed Phase 0
SHOPIFY_SHOPJO_READ_ONLY=true

# ---------- shopshibari.com ----------
# Phase 0 deferred --- Dev Dashboard access blocked. See docs/discovery.md.
# The myshopify handle below is a guess; confirm when access is restored.
SHOPIFY_SHOPSHIBARI_SHOP=shopshibari.myshopify.com
SHOPIFY_SHOPSHIBARI_CLIENT_ID=replace-with-client-id-from-dev-dashboard
SHOPIFY_SHOPSHIBARI_CLIENT_SECRET=replace-with-client-secret-from-dev-dashboard
SHOPIFY_SHOPSHIBARI_WEBHOOK_SECRET=
SHOPIFY_SHOPSHIBARI_PLUS=false                           # likely Advanced (per lubelife/shopjo pattern); re-verify via probe
SHOPIFY_SHOPSHIBARI_SUBSCRIPTION_PROVIDER=ordergroove    # assumed --- consistent with other two stores
SHOPIFY_SHOPSHIBARI_READ_ONLY=true

# =============================================================================
# Optional — third-party providers (only needed if Phase 0 discovery says so)
# =============================================================================

# ---------- OrderGroove (per store, the confirmed v1 subscription provider) ----------
# OrderGroove uses an API key + (often) a customer-public-id; confirm at provisioning.
ORDERGROOVE_LUBELIFE_API_KEY=
ORDERGROOVE_LUBELIFE_PUBLIC_ID=
ORDERGROOVE_SHOPJO_API_KEY=
ORDERGROOVE_SHOPJO_PUBLIC_ID=
ORDERGROOVE_SHOPSHIBARI_API_KEY=
ORDERGROOVE_SHOPSHIBARI_PUBLIC_ID=

# ---------- Google Analytics 4 fallback (per store, only where ShopifyQL fails the probe) ----------
# Each store needs its own service-account credential file path AND its GA4 property ID.
GA4_LUBELIFE_PROPERTY_ID=
GA4_LUBELIFE_CREDENTIALS_PATH=
GA4_SHOPJO_PROPERTY_ID=
GA4_SHOPJO_CREDENTIALS_PATH=
GA4_SHOPSHIBARI_PROPERTY_ID=
GA4_SHOPSHIBARI_CREDENTIALS_PATH=

# =============================================================================
# Observability (optional in dev)
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_METRICS_PORT=9090
